rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request coming from a signed-in admin/employee account?
    // NOTE: this project uses a custom localStorage-based login (not Firebase Auth),
    // so we can't check request.auth here. These rules allow the app to read/write
    // freely from the client, which matches how the site currently works.
    // If you later add real Firebase Authentication for admins, tighten this to
    // check request.auth.token instead.

    match /students/{studentId} {
      allow read: if true;
      allow write: if true;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if true;
    }

    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if true;
    }

    match /questionBank/{questionId} {
      allow read: if true;
      allow write: if true;
    }

    match /quizAttempts/{attemptId} {
      allow read: if true;
      allow write: if true;
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if true;
    }

    match /courseCodes/{codeId} {
      allow read: if true;
      allow write: if true;
    }

    match /paymentRequests/{requestId} {
      allow read: if true;
      allow write: if true;
    }

    match /activityLogs/{logId} {
      allow read: if true;
      allow write: if true;
    }

    // Catch-all fallback for any other collection used by the app
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
